# Analytics (optional)
NEXT_PUBLIC_GA_ID="G-ED5WFL7PCW"
NEXT_PUBLIC_YM_ID="107712908"

# Yandex Metrica API (server-side) - не требует пересборки
YM_ID="107712908"
# Get token: https://oauth.yandex.ru/authorize?response_type=token&client_id=<your_app_id>
METRICA_TOKEN=""

# Google Analytics 4 API (server-side)
# 1. Create Service Account in Google Cloud Console
# 2. Enable Analytics Data API
# 3. Download credentials.json and paste as JSON string
# 4. Add Service Account email to GA4 property users (Viewer)
GA4_PROPERTY_ID=""
GA4_CREDENTIALS='{"type":"service_account","project_id":"...","private_key":"...","client_email":"..."}'

# Google Analytics 4 Measurement ID (client-side, for gtag.js)
NEXT_PUBLIC_GA_MEASUREMENT_ID="G-ED5WFL7PCW"
